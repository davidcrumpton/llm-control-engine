{
  "provider": "openai",
  "model": "gpt-4",
  "temperature": 0.7,
  "maxTokens": 2048,
  "tools": {
    "directory": "./tools",
    "autoload": true
  },
  "providers": {
    "openai": {
      "apiKey": "test-key-openai",
      "baseUrl": "https://api.openai.com/v1",
      "organization": "test-org"
    },
    "anthropic": {
      "apiKey": "test-key-anthropic",
      "baseUrl": "https://api.anthropic.com"
    },
    "ollama": {
      "baseUrl": "http://localhost:11434",
      "keepAlive": "5m"
    }
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
