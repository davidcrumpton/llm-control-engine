{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Override dev-only settings */
    "noEmit": false,
    "allowImportingTsExtensions": false,

    /* Build output */
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },

  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
