
for key in $(env | grep -v API_KEY | grep LLMCTRLX | cut -d= -f1); do
  unset $key
done
### LLMCTRLX
export LLMCTRLX_TOOLS_DIR=~/llmctrlx/openai/tools
export LLMCTRLX_PLUGINS_DIR=~/llmctrlx/openai/plugins
export LLMCTRLX_HISTORY_FILE=~/llmctrlx/openai/history.json
export __LLMCTRLX_OPENAI_API_KEY=$(gpg -d ~/llmctrlx/openai/openai.api.key.asc)
export LLMCTRLX_MODEL=gpt-5.5
export LLMCTRLX_PROVIDER=openai
