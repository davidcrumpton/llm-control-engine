for key in $(env | grep -v API_KEY | grep LLMCTRLX | cut -d= -f1); do
  unset $key
done
### LLMCTRLX
export LLMCTRLX_API_URL=https://ollama.com/
export LLMCTRLX_TOOLS_DIR=~/llmctrlx/ollama/tools
export LLMCTRLX_PLUGINS_DIR=~/llmctrlx/ollama/plugins
export LLMCTRLX_HISTORY_FILE=~/llmctrlx/ollama/history.json
export __LLMCTRLX_OLLAMA_API_KEY=$(gpg -d ~/llmctrlx/ollama/ollama.api.key.asc)
export LLMCTRLX_MODEL=gemma3:4b
export LLMCTRLX_PROVIDER=ollama
