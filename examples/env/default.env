for key in $(env | grep -v API_KEY | grep LLMCTRLX | cut -d= -f1); do
  unset $key
done
### LLMCTRLX
export LLMCTRLX_TOOLS_DIR=~/llmctrlx/default/tools
export LLMCTRLX_PLUGINS_DIR=~/llmctrlx/default/plugins
export LLMCTRLX_HISTORY_FILE=~/llmctrlx/default/history.json
export LLMCTRLX_PROVIDER=ollama
