{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    /* Type Checking */
    "strict": true,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,

    /* Output */
    "outDir": "dist",
    "noEmit": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@tests/*": ["tests/*"]
    }
  },

  /* Include all TypeScript files in src and tests */
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ],

  /* Explicitly exclude build artifacts */
  "exclude": [
    "node_modules",
    "dist",
    "**/*.js"
  ]
}
